{
  "name": "blindfold-tower-server",
  "version": "1.5.0",
  "description": "Blindfold Tower – Colyseus game server",
  "main": "dist/index.js",
  "scripts": {
    "build":   "tsc",
    "start":   "node dist/index.js",
    "dev":     "ts-node-dev --respawn --transpile-only index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@colyseus/schema":       "^4.0.25",
    "@colyseus/ws-transport": "^0.17.13",
    "colyseus":               "^0.17.10",
    "cors":                   "^2.8.5",
    "express":                "^4.21.2",
    "matter-js":              "^0.19.0"
  },
  "devDependencies": {
    "@types/cors":            "^2.8.17",
    "@types/express":         "^4.17.21",
    "@types/matter-js":       "^0.19.8",
    "@types/node":            "^22.0.0",
    "ts-node-dev":            "^2.0.0",
    "ts-node":                "^10.9.2",
    "typescript":             "^5.7.3"
  }
}
